{
	"name": "alexa-mercadona",
	"version": "0.1.0",
	"private": true,
	"description": "Skill de Alexa que añade productos al carrito de Mercadona desde Mis Habituales",
	"type": "module",
	"scripts": {
		"cli": "tsx src/cli.ts",
		"build": "tsc -p .",
		"typecheck": "tsc -p . --noEmit",
		"package:lambda": "node scripts/package-lambda.mjs",
		"build:hosted": "node scripts/build-alexa-hosted.mjs"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"ask-sdk-core": "^2.14.0",
		"ask-sdk-model": "^1.86.0"
	},
	"devDependencies": {
		"@types/aws-lambda": "^8.10.145",
		"@types/node": "^24.10.4",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	}
}
